-- Function to modify reach (works on many games)
local function setReach(distance)
    -- Method 1: Modify Character's hitbox/arm size (works in many PvP games)
    local character = player.Character
    if character then
        for _, part in pairs(character:GetDescendants()) do
            if part:IsA("Part") or part:IsA("MeshPart") then
                -- Some games use this for reach detection
                part.Size = part.Size + Vector3.new(0, 0, distance - 10) -- subtle adjustment
            end
        end
    end
    
    -- Method 2: Modify tool reach if holding a tool
    local tool = character and character:FindFirstChildOfClass("Tool")
    if tool then
        local handle = tool:FindFirstChild("Handle")
        if handle then
            -- Some tools use handle size for reach
            handle.Size = handle.Size + Vector3.new(0, 0, distance - 10)
        end
    end
    
    -- Method 3: For games using raycast-based combat, inject custom distance
    -- This uses the game's own reach variables if available
    local gameReach = getgenv().Reach or 10
    getgenv().Reach = distance
    gameReach = distance
    
    statusLabel.Text = "Reach set to " .. math.round(distance) .. " (active)"
    statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
end

-- Update button action
updateButton.MouseButton1Click:Connect(function()
