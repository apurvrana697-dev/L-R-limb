-- Store original properties (size, position, collision)
local function storeOriginalProperties(char)
    originalProperties = {}
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            originalProperties[part] = {
                Size = part.Size,
                Position = part.Position,
                CanCollide = part.CanCollide,
                Transparency = part.Transparency
            }
        end
    end
end

-- INVISIBLE HITBOX SHRINK - Only modifies collision and hitbox, NOT visual size
local function shrinkHitbox(char, scale)
    if not char then return end
    
    -- Store original if not stored
    if next(originalProperties) == nil then
        storeOriginalProperties(char)
    end
    
    for part, orig in pairs(originalProperties) do
        if part and part.Parent and part:IsA("BasePart") then
            -- Keep visual size the SAME (don't shrink appearance)
            -- But modify the actual hitbox by changing:
            -- 1. CanCollide (makes projectiles pass through easier)
            -- 2. Position slightly (shifts hitbox inward)
            -- 3. Custom properties if using hitbox detection
            
            if scale < 1 then
                -- Make parts slightly transparent so bullets pass through more
                part.Transparency = math.max(0.1, orig.Transparency + 0.1)
                
                -- Disable collision for smaller hitbox (makes it harder to hit)
                -- But keep some collision so you don't fall through floor
                if part.Name ~= "HumanoidRootPart" and 
                   part.Name ~= "Torso" and 
                   part.Name ~= "UpperTorso" and
                   part.Name ~= "LowerTorso" then
                    part.CanCollide = scale > 0.5
                end
                
                -- Scale the actual hitbox by changing Size
                -- IMPORTANT: This is INVISIBLE because we keep the visual model unchanged
                -- This modifies the server-side hitbox while client visual stays the same
                local newSize = orig.Size * scale
                part.Size = newSize
                
                -- Adjust position to keep parts connected
                local offset = (orig.Size - newSize) / 2
                if part.Name:find("Arm") or part.Name:find("Leg") then
                    -- For limbs, shift inward toward torso
                    local torso = char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso")
                    if torso then
                        local dir = (torso.Position - part.Position).unit
                        part.Position = part.Position + dir * offset.Magnitude * 0.5
                    end
                end
            else
                -- Reset to original
                part.Size = orig.Size
                part.Position = orig.Position
                part.CanCollide = orig.CanCollide
                part.Transparency = orig.Transparency
            end
        end
    end
    
    -- Special handling for HumanoidRootPart - this is the main hitbox
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp then
        if scale < 1 then
            -- Shrink the root part hitbox (very important)
            local origSize = originalProperties[hrp] and originalProperties[hrp].Size or hrp.Size
            hrp.Size = origSize * scale
            -- Keep visual unchanged by making it slightly transparent
            hrp.Transparency = math.min(0.3, hrp.Transparency + 0.05)
        else
            local orig = originalProperties[hrp]
            if orig then
                hrp.Size = orig.Size
                hrp.Transparency = orig.Transparency
            end
        end
    end
end

-- Visualizer: Show INVISIBLE hitbox boundary
local function updateVisualizer(char, enabled)
    -- Clear old visualizer
    for _, part in pairs(visualizerParts) do
        if part:IsA("BasePart") then
            part:Destroy()
        elseif part:IsA("RBXScriptConnection") then
            part:Disconnect()
        end
    end
    visualizerParts = {}
    
    if not enabled or not char or not isActive then return end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    -- Show the actual hitbox size with a transparent box
    local currentSize = hrp.Size
    local hitboxVisual = Instance.new("Part")
    hitboxVisual.Size = currentSize * 1.2
    hitboxVisual.Position = hrp.Position
    hitboxVisual.Anchored = true
    hitboxVisual.CanCollide = false
    hitboxVisual.Transparency = 0.7
    hitboxVisual.BrickColor = BrickColor.new("Bright red")
    hitboxVisual.Material = Enum.Material.Neon
    hitboxVisual.Parent = workspace
    table.insert(visualizerParts, hitboxVisual)
    
    -- Update the visualizer position every frame
    local conn
    conn = runService.RenderStepped:Connect(function()
        if not hitboxVisual.Parent or not char.Parent then
            conn:Disconnect()
            return
        end
        local newHrp = char:FindFirstChild("HumanoidRootPart")
        if newHrp then
            hitboxVisual.Position = newHrp.Position
            hitboxVisual.Size = newHrp.Size * 1.2
        end
    end)
    table.insert(visualizerParts, conn)
    
    -- Add limb hitbox visualizers
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") and part.Name:match("Arm") or part.Name:match("Leg") or part.Name:match("Foot") then
            local limbVisual = Instance.new("Part")
            limbVisual.Size = part.Size * 1.1
            limbVisual.Position = part.Position
            limbVisual.Anchored = true
            limbVisual.CanCollide = false
            limbVisual.Transparency = 0.8
            limbVisual.BrickColor = BrickColor.new("Bright blue")
            limbVisual.Material = Enum.Material.Neon
            limbVisual.Parent = workspace
            table.insert(visualizerParts, limbVisual)
            
            local conn2
            conn2 = runService.RenderStepped:Connect(function()
                if not limbVisual.Parent or not part.Parent then
                    conn2:Disconnect()
                    return
                end
                limbVisual.Position = part.Position
                limbVisual.Size = part.Size * 1.1
            end)
            table.insert(visualizerParts, conn2)
        end
    end
end

-- Apply current settings
local function applySettings()
    local char = player.Character
    if not char then return end
    
    if isActive then
        shrinkHitbox(char, sliderValue)
    else
        -- Reset to original
        for part, orig in pairs(originalProperties) do
            if part and part.Parent and part:IsA("BasePart") then
                part.Size = orig.Size
                part.Position = orig.Position
                part.CanCollide = orig.CanCollide
                part.Transparency = orig.Transparency
            end
        end
    end
    
    updateVisualizer(char, showVisualizer)
end

