statusLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
statusLabel.TextScaled = true
statusLabel.Font = Enum.Font.Gotham
statusLabel.Parent = mainFrame

-- Info Label
local infoLabel = Instance.new("TextLabel")
infoLabel.Size = UDim2.new(1, 0, 0, 20)
infoLabel.Position = UDim2.new(0, 0, 0.55, 0)
infoLabel.BackgroundTransparency = 1
infoLabel.Text = "You cannot be hit at all"
infoLabel.TextColor3 = Color3.fromRGB(150, 150, 180)
infoLabel.TextScaled = true
infoLabel.Font = Enum.Font.Gotham
infoLabel.Parent = mainFrame

-- Function to apply TRUE i-frame state
local function applyTrueIFrames()
    if not character then return end
    
    -- Save original values if not saved
    if not originalHumanoid[character] then
        originalHumanoid[character] = {
            MaxHealth = humanoid.MaxHealth,
            Health = humanoid.Health,
            WalkSpeed = humanoid.WalkSpeed,
            JumpPower = humanoid.JumpPower
        }
    end
    
    -- Method 1: Disable damage events
    local damageConnection = game:GetService("RunService").Heartbeat:Connect(function()
        if character and character:FindFirstChild("Humanoid") then
            local hum = character.Humanoid
            -- Block all damage by constantly healing
            hum.Health = hum.MaxHealth
            -- Reset any damage attributes
            hum:SetAttribute("LastDamageTime", 0)
            hum:SetAttribute("DamageCooldown", 0)
            -- Clear any break joints
            if character:FindFirstChild("BreakJoints") then
                character.BreakJoints:Destroy()
            end
        end
    end)
    table.insert(iframeConnections, damageConnection)
    
    -- Method 2: Block hitbox detection (prevents attacks from registering)
    local hitboxConnection = game:GetService("RunService").Stepped:Connect(function()
        if character then
            -- Disable hitbox detection by making character intangible
            for _, part in ipairs(character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                    part.Transparency = 0.3
                    part.Material = Enum.Material.Neon
                end
            end
            -- Also disable any hitbox scripts
            if character:FindFirstChild("Hitbox") then
                character.Hitbox:Destroy()
            end
            if character:FindFirstChild("HitBox") then
                character.HitBox:Destroy()
            end
        end
    end)
    table.insert(iframeConnections, hitboxConnection)
    
    -- Method 3: Block damage events from server
    local eventConnection = game:GetService("RunService").Heartbeat:Connect(function()
        if character then
            -- Intercept and block damage events
            local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
            if humanoidRootPart then
                humanoidRootPart:SetAttribute("DamageCooldown", 0)
                humanoidRootPart:SetAttribute("LastHitTime", 0)
            end
            -- Reset health every frame to prevent any damage sticking
            humanoid.Health = humanoid.MaxHealth
        end
    end)
    table.insert(iframeConnections, eventConnection)
    
    -- Method 4: Prevent any debuffs or stuns
    local debuffConnection = game:GetService("RunService").Stepped:Connect(function()
        if humanoid then
            -- Remove any stuns or debuffs
            humanoid.PlatformStand = false
            humanoid.Sit = false
            -- Keep health full
            humanoid.Health = humanoid.MaxHealth
        end
    end)
    table.insert(iframeConnections, debuffConnection)
end

-- Function to remove i-frame state
local function removeTrueIFrames()
    for _, connection in ipairs(iframeConnections) do
        connection:Disconnect()
    end
    iframeConnections = {}
    
    if character then
        -- Restore original values
        if originalHumanoid[character] then
            local orig = originalHumanoid[character]
            humanoid.MaxHealth = orig.MaxHealth or 100
            humanoid.Health = orig.Health or 100
            humanoid.WalkSpeed = orig.WalkSpeed or 16
            humanoid.JumpPower = orig.JumpPower or 50
        end
        
        -- Restore parts
        for _, part in ipairs(character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = true
                part.Transparency = 0
                part.Material = Enum.Material.Plastic
            end
        end
    end
end

-- Main toggle function
local function toggleIFrames()
    iframesEnabled = not iframesEnabled
    
    if iframesEnabled then
        iframeButton.Text = "I-FRAMES: ON"
        iframeButton.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
        statusLabel.Text = "Status: TRUE I-FRAMES ACTIVE"
        statusLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
        infoLabel.Text = "You are completely unhittable"
        infoLabel.TextColor3 = Color3.fromRGB(0, 255, 200)
        
        applyTrueIFrames()
    else
        iframeButton.Text = "I-FRAMES: OFF"
        iframeButton.BackgroundColor3 = Color3.fromRGB(40, 40, 60)
        statusLabel.Text = "Status: Disabled"
        statusLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
        infoLabel.Text = "You can be hit normally"
        infoLabel.TextColor3 = Color3.fromRGB(150, 150, 180)
        
        removeTrueIFrames()
    end
end

-- UI toggle
local function toggleUI()
    uiVisible = not uiVisible
    mainFrame.Visible = uiVisible
    toggleUIButton.Text = uiVisible and "HIDE UI" or "SHOW UI"
    toggleUIButton.BackgroundColor3 = uiVisible and Color3.fromRGB(80, 50, 50) or Color3.fromRGB(50, 80, 50)
end

-- Connect buttons
iframeButton.MouseButton1Click:Connect(toggleIFrames)
toggleUIButton.MouseButton1Click:Connect(toggleUI)

-- Handle character respawn
player.CharacterAdded:Connect(function(newChar)
    character = newChar
    humanoid = character:WaitForChild("Humanoid")
    
    -- Clear old connections
    for _, connection in ipairs(iframeConnections) do
        connection:Disconnect()
    end
    iframeConnections = {}
    
    -- Reapply if enabled
    if iframesEnabled then
        applyTrueIFrames()
    end
end)

print("JJS TRUE Infinite I-Frames Script Loaded!")
print("You cannot be hit when I-FRAMES is ON")
