-- JJ's Battleground M1 Speed & I-Frame Exploit Script WITH SLIDERS
-- Works with most popular executors (Synapse, Krnl, ScriptWare, etc.)

local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local combatModule = nil
local library = loadstring(game:HttpGet("https://raw.githubusercontent.com/7GrandDadPGN/VapeV4ForRoblox/main/UI-Libraries/Synapse%20X%20V3"))()

-- Find the combat module
for _, module in ipairs(getgc(true)) do
    if type(module) == "table" and rawget(module, "M1Cooldown") then
        combatModule = module
        break
    end
end

if not combatModule then
    warn("Combat module not found - using alternative method")
end

-- Create the GUI window
local window = library:CreateWindow("M1 Exploit Config")
local mainTab = window:CreateTab("M1 Settings")

-- Variables with default values
local settings = {
    iframeDuration = 0.3,
    endlag = 0.03,
    startup = 0.02,
    animationSpeed = 3.0,
    enabled = true
}

-- Apply settings function
local function applySettings()
    if not settings.enabled then return end
    
    if combatModule then
        combatModule.M1Cooldown = settings.endlag
        combatModule.M1Startup = settings.startup
        combatModule.M1Endlag = settings.endlag
        combatModule.M1IFrames = true
        combatModule.M1IFrameDuration = settings.iframeDuration
    end
    
    -- Animation speed
    local animator = character:FindFirstChild("Animator")
    if animator then
        for _, track in pairs(animator:GetPlayingAnimationTracks()) do
            if track.Name:lower():find("punch") or track.Name:lower():find("m1") then
                track:AdjustSpeed(settings.animationSpeed)
            end
        end
    end
end

-- SLIDER: I-Frame Duration
mainTab:CreateSlider({
    Name = "I-Frame Duration (seconds)",
    Min = 0,
    Max = 1.0,
    Default = settings.iframeDuration,
    Color = Color3.fromRGB(255, 50, 50),
    Increment = 0.01,
    Callback = function(value)
        settings.iframeDuration = value
        applySettings()
        print("I-Frame duration set to: " .. value .. "s")
    end
})

-- SLIDER: Endlag (cooldown between punches)
mainTab:CreateSlider({
    Name = "Endlag (cooldown between M1s)",
    Min = 0.01,
    Max = 0.5,
    Default = settings.endlag,
    Color = Color3.fromRGB(50, 255, 50),
    Increment = 0.01,
    Callback = function(value)
        settings.endlag = value
        applySettings()
        print("Endlag set to: " .. value .. "s")
    end
})

-- SLIDER: Startup Speed (animation startup time)
mainTab:CreateSlider({
    Name = "Startup Speed (time before punch lands)",
    Min = 0.01,
    Max = 0.3,
    Default = settings.startup,
    Color = Color3.fromRGB(50, 150, 255),
    Increment = 0.01,
    Callback = function(value)
        settings.startup = value
        applySettings()
        print("Startup set to: " .. value .. "s")
    end
})

-- SLIDER: Animation Speed Multiplier
mainTab:CreateSlider({
    Name = "Animation Speed Multiplier",
    Min = 0.5,
    Max = 10.0,
    Default = settings.animationSpeed,
    Color = Color3.fromRGB(255, 200, 50),
    Increment = 0.1,
    Callback = function(value)
        settings.animationSpeed = value
        applySettings()
        print("Animation speed set to: " .. value .. "x")
    end
})

-- Toggle: Enable/Disable all modifications
mainTab:CreateToggle({
    Name = "Enable M1 Modifications",
    Default = true,
    Callback = function(state)
        settings.enabled = state
        if state then
            applySettings()
            print("M1 modifications ENABLED")
        else
            -- Reset to default values
            if combatModule then
                combatModule.M1Cooldown = 0.3
                combatModule.M1Startup = 0.15
                combatModule.M1Endlag = 0.2
                combatModule.M1IFrames = false
            end
            print("M1 modifications DISABLED")
        end
    end
})

-- Display current values label
local valueDisplay = mainTab:CreateLabel("Current Values: I-Frame: " .. settings.iframeDuration .. "s | Endlag: " .. settings.endlag .. "s | Startup: " .. settings.startup .. "s")

-- Update label when sliders change
local function updateLabel()
    valueDisplay:SetText("Current Values: I-Frame: " .. settings.iframeDuration .. "s | Endlag: " .. settings.endlag .. "s | Startup: " .. settings.startup .. "s | Anim Speed: " .. settings.animationSpeed .. "x")
end

-- Override slider callbacks to update label
-- (Simplified - you'd need to modify the slider creation to call updateLabel)

-- Apply initial settings
applySettings()

-- Keep modifications active on respawn
player.CharacterAdded:Connect(function(newChar)
    character = newChar
    humanoid = character:WaitForChild("Humanoid")
    wait(0.1)
    applySettings()
end)

print("M1 Exploit GUI loaded!")
print("Use the sliders to adjust I-Frame, Endlag, and Startup in real-time")
print("You should see immediate changes when sliding")
