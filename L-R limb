-- JJS No Stun Hack - FIXED VERSION
-- Works with actual JJS stun mechanics

local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")

-- Variables
local noStunEnabled = false
local stunAmount = 0.5
local uiVisible = true
local defaultStun = 0.5
local isStunned = false

-- Function to actually remove stun
local function removeStun()
    if not character or not humanoid then return end
    
    -- Method 1: Reset WalkSpeed if it's below normal (stunned)
    if humanoid.WalkSpeed < 16 and humanoid.WalkSpeed > 0 then
        humanoid.WalkSpeed = 16
    end
    
    -- Method 2: Remove stun from JJS specific stun system
    for _, v in pairs(character:GetDescendants()) do
        -- Common JJS stun indicators
        if v:IsA("BoolValue") and v.Name == "Stunned" then
            v.Value = false
        end
        if v:IsA("NumberValue") and (v.Name == "StunTime" or v.Name == "StunDuration") then
            v.Value = 0
        end
        if v:IsA("StringValue") and v.Name == "State" and v.Value == "Stunned" then
            v.Value = "Idle"
        end
        -- Animation track stun removal
        if v:IsA("AnimationTrack") and v.Name == "StunAnim" then
            v:Stop()
        end
    end
    
    -- Method 3: Force movement capability
    if humanoid:GetState() == Enum.HumanoidStateType.Physics then
        humanoid:ChangeState(Enum.HumanoidStateType.Running)
    end
    if humanoid:GetState() == Enum.HumanoidStateType.FallingDown then
        humanoid:ChangeState(Enum.HumanoidStateType.Running)
    end
    
    -- Method 4: Remove any stun debuffs from character
    local stunDebuff = character:FindFirstChild("StunDebuff")
    if stunDebuff then
        stunDebuff:Destroy()
    end
    
    local stunEffect = character:FindFirstChild("StunEffect")
    if stunEffect then
        stunEffect:Destroy()
    end
end

-- Function to apply custom stun amount
local function applyCustomStun()
    if not character or not humanoid then return end
    
    if noStunEnabled then
        -- Keep speed at normal or higher based on slider
        local speedMultiplier = 1 + (stunAmount * 2)
        humanoid.WalkSpeed = math.clamp(16 * speedMultiplier, 16, 40)
    else
        humanoid.WalkSpeed = 16
    end
end

