-- Get all parts and their original sizes
local function storeOriginalSizes(char)
    originalSizes = {}
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            originalSizes[part] = part.Size
        end
    end
end

-- Scale character hitbox
local function scaleHitbox(char, scale)
    if not char then return end
    
    -- Store original sizes if not stored
    if next(originalSizes) == nil then
        storeOriginalSizes(char)
    end
    
    -- Scale all BaseParts
    for part, origSize in pairs(originalSizes) do
        if part and part.Parent and part:IsA("BasePart") then
            part.Size = origSize * scale
        end
    end
    
    -- Scale Motor6D joints for proper limb positioning
    for _, v in pairs(char:GetDescendants()) do
        if v:IsA("Motor6D") then
            local c0 = v.C0
            local c1 = v.C1
            v.C0 = CFrame.new(c0.Position * scale) * CFrame.Angles(c0:ToEulerAnglesXYZ())
            v.C1 = CFrame.new(c1.Position * scale) * CFrame.Angles(c1:ToEulerAnglesXYZ())
        end
    end
end

-- Visualizer: Show bounding box around character
local function updateVisualizer(char, enabled)
    -- Clear old visualizer
    for _, part in pairs(visualizerParts) do
        part:Destroy()
    end
    visualizerParts = {}
    
    if not enabled or not char then return end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    -- Create a bounding box visual
    local size = hrp.Size * 1.5
    local visual = Instance.new("SelectionBox")
    visual.Adornee = hrp
    visual.Color3 = Color3.fromRGB(0, 200, 255)
    visual.Transparency = 0.5
    visual.LineThickness = 0.05
    visual.Parent = hrp
    table.insert(visualizerParts, visual)
    
    -- Add corner markers
    for x = -1, 1, 2 do
        for y = -1, 1, 2 do
            for z = -1, 1, 2 do
                local marker = Instance.new("Part")
                marker.Size = Vector3.new(0.2, 0.2, 0.2)
                marker.Position = hrp.Position + Vector3.new(x * size.X/2, y * size.Y/2, z * size.Z/2)
                marker.Anchored = true
                marker.CanCollide = false
                marker.Transparency = 0.3
                marker.BrickColor = BrickColor.new("Cyan")
                marker.Material = Enum.Material.Neon
                marker.Parent = workspace
                table.insert(visualizerParts, marker)
                
                -- Update marker position every frame
                local conn
                conn = game:GetService("RunService").RenderStepped:Connect(function()
                    if not marker.Parent then
                        conn:Disconnect()
                        return
                    end
                    local newHrp = char:FindFirstChild("HumanoidRootPart")
                    if newHrp then
                        marker.Position = newHrp.Position + Vector3.new(x * size.X/2, y * size.Y/2, z * size.Z/2)
                    end
                end)
                table.insert(visualizerParts, conn)
            end
        end
    end
end

-- Apply current settings
local function applySettings()
    local char = player.Character
    if not char then return end
    
    if isActive then
        scaleHitbox(char, sliderValue)
    else
        -- Reset to original
        for part, origSize in pairs(originalSizes) do
            if part and part.Parent and part:IsA("BasePart") then
                part.Size = origSize
            end
        end
        -- Reset joints
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("Motor6D") then
                v.C0 = v.C0
                v.C1 = v.C1
            end
        end
    end
    
    updateVisualizer(char, showVisualizer and isActive)
end

