-- Main arm aiming function - SIMPLE APPROACH without flinging
local function aimArm()
    if not isActive then return end
    if not isAiming then 
        if alignOrientation then
            alignOrientation.Enabled = false
        end
        return 
    end
    if not targetPlayer then 
        if alignOrientation then
            alignOrientation.Enabled = false
        end
        return 
    end
    
    local targetChar = targetPlayer.Character
    if not targetChar then 
        if alignOrientation then
            alignOrientation.Enabled = false
        end
        return 
    end
    
    local targetArm = getClosestArm(targetChar)
    if not targetArm then 
        if alignOrientation then
            alignOrientation.Enabled = false
        end
        return 
    end
    
    local playerArm = getPlayerArm()
    if not playerArm then return end
    
    -- Calculate direction to target arm
    local direction = (targetArm.Position - playerArm.Position).unit
    
    -- SIMPLE: Just rotate the arm using CFrame angles without moving it
    -- This is the most stable method
    local lookAtCFrame = CFrame.lookAt(Vector3.new(0,0,0), direction)
    
    -- Apply only rotation, keep position exactly the same
    local newCFrame = CFrame.new(playerArm.Position) * lookAtCFrame.Rotation
    playerArm.CFrame = newCFrame
    
    -- IMPORTANT: We also need to update the child parts of the arm
    -- But this is the simplest approach that won't fling
end

