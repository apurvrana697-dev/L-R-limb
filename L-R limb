-- Functions
local function updateNoStun()
    if noStunEnabled then
        humanoid.WalkSpeed = 16 -- Keep speed normal
        -- Disable stun effects
        for _, v in pairs(character:GetDescendants()) do
            if v:IsA("NumberValue") and v.Name == "Stun" then
                v.Value = stunAmount
            end
        end
    end
end

-- Toggle No Stun
toggleButton.MouseButton1Click:Connect(function()
    noStunEnabled = not noStunEnabled
    toggleLabel.Text = "No Stun: " .. (noStunEnabled and "ON" or "OFF")
    toggleLabel.TextColor3 = noStunEnabled and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(255, 100, 100)
    toggleButton.Text = noStunEnabled and "Disable" or "Enable"
    if noStunEnabled then
        updateNoStun()
    end
end)

-- Slider functionality
local dragging = false

sliderButton.MouseButton1Down:Connect(function()
    dragging = true
end)

game:GetService("UserInputService").InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

game:GetService("RunService").RenderStepped:Connect(function()
    if dragging then
        local mouse = player:GetMouse()
        local sliderPos = slider.AbsolutePosition.X
        local sliderSize = slider.AbsoluteSize.X
        local newX = math.clamp(mouse.X - sliderPos, 0, sliderSize)
        local percent = newX / sliderSize
        stunAmount = math.round(percent * 10) / 10
        stunAmount = math.clamp(stunAmount, 0, 1)
        sliderFill.Size = UDim2.new(percent, 0, 1, 0)
        sliderLabel.Text = "Stun Amount: " .. string.format("%.1f", stunAmount)
        if noStunEnabled then
            updateNoStun()
        end
    end
end)

-- Reset to default
resetButton.MouseButton1Click:Connect(function()
    stunAmount = defaultStun
    sliderFill.Size = UDim2.new(0.5, 0, 1, 0)
    sliderLabel.Text = "Stun Amount: " .. string.format("%.1f", stunAmount)
    if noStunEnabled then
        updateNoStun()
    end
end)

-- Toggle UI Visibility
toggleUIButton.MouseButton1Click:Connect(function()
    uiVisible = not uiVisible
    mainFrame.Visible = uiVisible
    miniToggle.Visible = not uiVisible
    toggleUIButton.Text = uiVisible and "Close UI" or "Open UI"
end)

miniToggle.MouseButton1Click:Connect(function()
    uiVisible = not uiVisible
    mainFrame.Visible = uiVisible
    miniToggle.Visible = not uiVisible
    toggleUIButton.Text = uiVisible and "Close UI" or "Open UI"
end)

-- Character respawn handling
player.CharacterAdded:Connect(function(newChar)
    character = newChar
    humanoid = character:WaitForChild("Humanoid")
    wait(0.5)
    if noStunEnabled then
        updateNoStun()
    end
end)

-- Main loop to keep stun disabled
game:GetService("RunService").Heartbeat:Connect(function()
    if noStunEnabled and character and humanoid then
        updateNoStun()
    end
end)

-- Initial setup
sliderFill.Size = UDim2.new(0.5, 0, 1, 0)
