-- Main loop - constantly checks and removes stun
game:GetService("RunService").Heartbeat:Connect(function()
    if noStunEnabled and character and humanoid then
        -- Remove stun every frame if needed
        if humanoid.WalkSpeed < 16 and humanoid.WalkSpeed > 0 then
            humanoid.WalkSpeed = 16 * (1 + (stunAmount * 2))
        end
        -- Remove any stun states
        for _, v in pairs(character:GetDescendants()) do
            if v:IsA("BoolValue") and v.Name == "Stunned" and v.Value == true then
                v.Value = false
            end
            if v:IsA("StringValue") and v.Name == "State" and v.Value == "Stunned" then
                v.Value = "Idle"
            end
        end
        -- Reset physics state
        if humanoid:GetState() == Enum.HumanoidStateType.Physics then
            humanoid:ChangeState(Enum.HumanoidStateType.Running)
        end
    end
end)

