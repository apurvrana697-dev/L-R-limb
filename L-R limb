-- JJS Infinite I-Frames Script
-- UI with toggle and I-Frame on/off button

local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")

-- Variables
local iframesEnabled = false
local uiVisible = true
local iframeConnection = nil

-- Create ScreenGui
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "IFrameUI"
screenGui.Parent = player.PlayerGui

-- Main Frame (UI Container)
local mainFrame = Instance.new("Frame")
mainFrame.Size = UDim2.new(0, 250, 0, 150)
mainFrame.Position = UDim2.new(0.5, -125, 0.5, -75)
mainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
mainFrame.BackgroundTransparency = 0.1
mainFrame.BorderSizePixel = 2
mainFrame.BorderColor3 = Color3.fromRGB(100, 150, 255)
mainFrame.ClipsDescendants = true
mainFrame.Parent = screenGui

-- Title Label
local titleLabel = Instance.new("TextLabel")
titleLabel.Size = UDim2.new(1, 0, 0, 30)
titleLabel.Position = UDim2.new(0, 0, 0, 0)
titleLabel.BackgroundTransparency = 1
titleLabel.Text = "JJS I-Frame Controller"
titleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
titleLabel.TextScaled = true
titleLabel.Font = Enum.Font.GothamBold
titleLabel.Parent = mainFrame

-- I-Frame Toggle Button
local iframeButton = Instance.new("TextButton")
iframeButton.Size = UDim2.new(0.8, 0, 0, 40)
iframeButton.Position = UDim2.new(0.1, 0, 0.3, 0)
iframeButton.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
iframeButton.BorderSizePixel = 1
iframeButton.BorderColor3 = Color3.fromRGB(150, 150, 200)
iframeButton.Text = "I-FRAMES: OFF"
iframeButton.TextColor3 = Color3.fromRGB(255, 255, 255)
iframeButton.TextScaled = true
iframeButton.Font = Enum.Font.Gotham
iframeButton.Parent = mainFrame

-- Close/Open Toggle Button
local toggleUIButton = Instance.new("TextButton")
toggleUIButton.Size = UDim2.new(0.3, 0, 0, 30)
toggleUIButton.Position = UDim2.new(0.35, 0, 0.75, 0)
toggleUIButton.BackgroundColor3 = Color3.fromRGB(80, 50, 50)
toggleUIButton.BorderSizePixel = 1
toggleUIButton.BorderColor3 = Color3.fromRGB(200, 100, 100)
toggleUIButton.Text = "CLOSE UI"
toggleUIButton.TextColor3 = Color3.fromRGB(255, 255, 255)
toggleUIButton.TextScaled = true
toggleUIButton.Font = Enum.Font.Gotham
toggleUIButton.Parent = mainFrame

-- Status Label
local statusLabel = Instance.new("TextLabel")
statusLabel.Size = UDim2.new(1, 0, 0, 20)
statusLabel.Position = UDim2.new(0, 0, 0.65, 0)
statusLabel.BackgroundTransparency = 1
statusLabel.Text = "Status: Disabled"
statusLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
statusLabel.TextScaled = true
statusLabel.Font = Enum.Font.Gotham
statusLabel.Parent = mainFrame

-- Function to toggle I-Frames
local function toggleIFrames()
    iframesEnabled = not iframesEnabled
    
    if iframesEnabled then
        iframeButton.Text = "I-FRAMES: ON"
        iframeButton.BackgroundColor3 = Color3.fromRGB(50, 100, 50)
        statusLabel.Text = "Status: Active (Infinite I-Frames)"
        statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        
        -- Enable infinite i-frames by continuously resetting damage cooldown
        iframeConnection = game:GetService("RunService").Heartbeat:Connect(function()
            if character and character:FindFirstChild("Humanoid") then
                local hum = character.Humanoid
                -- Reset damage cooldown constantly
                hum:SetAttribute("LastDamageTime", 0)
                -- Also attempt to block damage events
                hum.MaxHealth = 9999
                hum.Health = 9999
            end
        end)
    else
        iframeButton.Text = "I-FRAMES: OFF"
        iframeButton.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
        statusLabel.Text = "Status: Disabled"
        statusLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
        
        if iframeConnection then
            iframeConnection:Disconnect()
            iframeConnection = nil
        end
        
        -- Reset health to normal
        if character and character:FindFirstChild("Humanoid") then
            character.Humanoid.MaxHealth = 100
            character.Humanoid.Health = 100
        end
    end
end

-- Function to toggle UI visibility
local function toggleUI()
    uiVisible = not uiVisible
    mainFrame.Visible = uiVisible
    toggleUIButton.Text = uiVisible and "CLOSE UI" or "OPEN UI"
    toggleUIButton.BackgroundColor3 = uiVisible and Color3.fromRGB(80, 50, 50) or Color3.fromRGB(50, 80, 50)
end

-- Connect buttons
iframeButton.MouseButton1Click:Connect(toggleIFrames)
toggleUIButton.MouseButton1Click:Connect(toggleUI)

-- Handle character respawn
player.CharacterAdded:Connect(function(newChar)
    character = newChar
    humanoid = character:WaitForChild("Humanoid")
    
    -- Reapply iframes if enabled
    if iframesEnabled then
        if iframeConnection then
            iframeConnection:Disconnect()
        end
        iframeConnection = game:GetService("RunService").Heartbeat:Connect(function()
            if character and character:FindFirstChild("Humanoid") then
                local hum = character.Humanoid
                hum:SetAttribute("LastDamageTime", 0)
                hum.MaxHealth = 9999
                hum.Health = 9999
            end
        end)
    end
end)

-- Initial setup
print("JJS Infinite I-Frame Script Loaded!")
print("Use UI to toggle I-Frames on/off")
