-- Variables
local minVal = 5
local maxVal = 30
local currentVal = 10
local dragging = false
local reachEnabled = false
local currentReach = 10

-- Update slider visuals
local function updateSlider(value)
    local clamped = math.clamp(value, minVal, maxVal)
    local percent = (clamped - minVal) / (maxVal - minVal)
    sliderFill.Size = UDim2.new(percent, 0, 1, 0)
    handle.Position = UDim2.new(percent, -10, 0, -6)
    valDisplay.Text = "Reach: " .. math.round(clamped)
    currentVal = math.round(clamped)
end

-- ACTUAL REACH METHODS
local function applyReach(distance)
    local dist = math.round(distance)
    currentReach = dist
    reachEnabled = true
    
    -- METHOD 1: Global variable for scripts that check it
    getgenv().Reach = dist
    getgenv().ReachDistance = dist
    _G.Reach = dist
    _G.ReachDistance = dist
    
    -- METHOD 2: Modify mouse target distance (works in many games)
    if mouse then
        pcall(function()
            -- Some games use Mouse.TargetDistance
            mouse.TargetDistance = dist * 3
        end)
    end
    
    -- METHOD 3: Modify camera's max distance
    local camera = workspace.CurrentCamera
    if camera then
        pcall(function()
            camera.MaxZoomDistance = dist * 5
        end)
    end
    
    -- METHOD 4: Find and modify melee weapon values
    local character = player.Character
    if character then
        for _, tool in pairs(character:GetChildren()) do
            if tool:IsA("Tool") then
                -- Check for common reach properties
                for _, child in pairs(tool:GetDescendants()) do
                    if child:IsA("NumberValue") then
                        local name = child.Name:lower()
                        if name:match("range") or name:match("reach") or name:match("distance") then
                            pcall(function()
                                child.Value = dist
                            end)
                        end
                    end
                    if child:IsA("NumberValue") and child.Name == "Range" then
                        pcall(function()
                            child.Value = dist
                        end)
                    end
                end
                -- Some tools use Handle size
                local handle = tool:FindFirstChild("Handle")
                if handle then
                    pcall(function()
                        local oldSize = handle.Size
                        handle.Size = Vector3.new(oldSize.X, oldSize.Y, oldSize.Z + dist)
                    end)
                end
            end
        end
    end
    
    -- METHOD 5: Scan game for reach-related values
    for _, obj in pairs(game:GetDescendants()) do
        if obj:IsA("NumberValue") then
            local name = obj.Name:lower()
            if name:match("reach") or name:match("range") or name:match("dist") then
                if name ~= "fov" and name ~= "volume" then
                    pcall(function()
                        obj.Value = dist
                    end)
                end
            end
        end
        -- Check for NumberValue inside combat modules
        if obj:IsA("ModuleScript") and obj.Name:lower():match("combat") then
            pcall(function()
                -- Try to require and modify if possible
                local success, module = pcall(function()
                    return require(obj)
                end)
                if success and type(module) == "table" then
                    if module.Reach then module.Reach = dist end
                    if module.Range then module.Range = dist end
                    if module.Distance then module.Distance = dist end
                    if module.MaxDistance then module.MaxDistance = dist end
                end
            end)
        end
    end
    
    -- METHOD 6: Use remote event injection (for games using remotes)
    for _, remote in pairs(game:GetDescendants()) do
        if remote:IsA("RemoteEvent") or remote:IsA("RemoteFunction") then
            local name = remote.Name:lower()
            if name:match("attack") or name:match("combat") or name:match("melee") then
                pcall(function()
                    -- Store original for reference
                    if not remote._originalReach then
                        remote._originalReach = dist
                    end
                    -- Some remotes can be hooked
                end)
            end
        end
    end
    
    status.Text = "✅ Reach set to " .. dist
    status.TextColor3 = Color3.fromRGB(100, 255, 150)
end

-- Slider handle dragging
handle.MouseButton1Down:Connect(function()
    dragging = true
    status.Text = "⚡ Adjusting..."
    status.TextColor3 = Color3.fromRGB(255, 200, 50)
end)

userInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        if dragging then
            dragging = false
            status.Text = "✅ Ready - click Apply"
            status.TextColor3 = Color3.fromRGB(100, 255, 150)
        end
    end
end)

userInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local framePos = mainFrame.AbsolutePosition
        local frameSize = mainFrame.AbsoluteSize
        local mouseX = input.Position.X
        
        local trackX = framePos.X + 10
        local trackWidth = frameSize.X - 20
        
        if mouseX >= trackX and mouseX <= trackX + trackWidth then
            local percent = (mouseX - trackX) / trackWidth
            local value = minVal + (maxVal - minVal) * percent
            updateSlider(value)
        end
    end
end)

-- Click on track
sliderBg.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        local framePos = mainFrame.AbsolutePosition
        local frameSize = mainFrame.AbsoluteSize
        local mouseX = input.Position.X
        
        local trackX = framePos.X + 10
        local trackWidth = frameSize.X - 20
        
        if mouseX >= trackX and mouseX <= trackX + trackWidth then
            local percent = (mouseX - trackX) / trackWidth
            local value = minVal + (maxVal - minVal) * percent
            updateSlider(value)
            status.Text = "⚡ " .. math.round(value) .. " selected"
            status.TextColor3 = Color3.fromRGB(255, 200, 50)
        end
    end
end)

