-- JJ's Battleground M1 Speed & I-Frame Exploit Script
-- Works with most popular executors (Synapse, Krnl, ScriptWare, etc.)

local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local combatModule = nil

-- Find the combat module (adjust path as needed)
for _, module in ipairs(getgc(true)) do
    if type(module) == "table" and rawget(module, "M1Cooldown") then
        combatModule = module
        break
    end
end

if not combatModule then
    warn("Combat module not found - using alternative method")
end

-- Function to modify M1 properties
local function modifyM1()
    -- Method 1: Direct module manipulation
    if combatModule then
        -- Reduce endlag (cooldown between punches)
        combatModule.M1Cooldown = 0.05  -- Default is usually 0.3-0.5
        combatModule.M1Startup = 0.02   -- Faster startup animation
        combatModule.M1Endlag = 0.03    -- Less recovery time
        
        -- Add iframes during punch
        combatModule.M1IFrames = true
        combatModule.M1IFrameDuration = 0.3  -- 0.3 seconds of invincibility
    end
    
    -- Method 2: Animation speed manipulation
    local animator = character:FindFirstChild("Animator")
    if animator then
        for _, track in pairs(animator:GetPlayingAnimationTracks()) do
            if track.Name:lower():find("punch") or track.Name:lower():find("m1") then
                track:AdjustSpeed(3.0)  -- 3x faster animation speed
            end
        end
    end
    
    -- Method 3: Remote event spam (bypasses cooldown checks)
    local remoteEvents = {}
    for _, item in pairs(getconnections(game.ReplicatedStorage:FindFirstChild("RemoteEvent"))) do
        if item.Name and item.Name:lower():find("attack") then
            table.insert(remoteEvents, item)
        end
    end
    
    -- Spam remote to override server cooldown
    spawn(function()
        while wait(0.01) do
            for _, remote in ipairs(remoteEvents) do
                if remote and remote.Parent then
                    remote:FireServer("M1", "instant")
                end
            end
        end
    end)
end

-- Apply modifications when character loads
modifyM1()

-- Keep modifications active if character respawns
player.CharacterAdded:Connect(function(newChar)
    character = newChar
    humanoid = character:WaitForChild("Humanoid")
    wait(0.1)
    modifyM1()
end)

-- Extra: Auto-clicker for maximum speed
local autoClick = true
local m1Key = "MouseButton1"  -- Left click

game:GetService("UserInputService").InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and input.UserInputType == Enum.UserInputType.MouseButton1 then
        if autoClick then
            spawn(function()
                while autoClick and game:GetService("UserInputService"):IsMouseButtonPressed(Enum.UserInputType.MouseButton1) do
                    -- Simulate rapid M1 presses
                    for i = 1, 5 do
                        -- Trigger punch animation/event
                        if combatModule and combatModule.Punch then
                            combatModule:Punch()
                        end
                        wait(0.01)
                    end
                    wait(0.02)
                end
            end)
        end
    end
end)

print("M1 Speed & I-Frame Exploit Active!")
print("Endlag reduced | Startup sped up | I-Frames added")
