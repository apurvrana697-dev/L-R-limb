    return character
end

-- Toggle UI visibility (V key)
local uiToggleKey = Enum.KeyCode.V
local uiVisible = false

userInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    
    if input.KeyCode == uiToggleKey then
        uiVisible = not uiVisible
        mainFrame.Visible = uiVisible
    end
    
    if input.KeyCode == Enum.KeyCode.F1 then
        isActive = not isActive
        toggleBtn.BackgroundColor3 = isActive and Color3.fromRGB(60, 200, 100) or Color3.fromRGB(220, 60, 60)
        toggleBtn.Text = isActive and "ON" or "OFF"
        
        if isActive then
            statusLabel.Text = "⚡ Aiming at: " .. (targetPlayer and targetPlayer.Name or "None") .. " 🟢 ACTIVE"
        else
            statusLabel.Text = string.gsub(statusLabel.Text, " 🟢 ACTIVE", "")
            isAiming = false
        end
    end
    
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        if isActive and targetPlayer then
            isAiming = true
        end
    end
end)

userInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        isAiming = false
    end
end)

-- Function to update dropdown list
local function updateDropdown()
    for _, child in pairs(listFrame:GetChildren()) do
        if child ~= noneOption and child:IsA("TextButton") then
            child:Destroy()
        end
    end
    
    local players = targetService:GetPlayers()
    local count = 1
    for _, p in pairs(players) do
        if p ~= player and p.Character then
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, 0, 0, 32)
            btn.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
            btn.Text = p.Name
            btn.TextColor3 = Color3.fromRGB(220, 220, 230)
            btn.TextScaled = true
            btn.Font = Enum.Font.Gotham
            btn.Parent = listFrame
            
            local btnCorner = Instance.new("UICorner")
            btnCorner.CornerRadius = UDim.new(0, 4)
            btnCorner.Parent = btn
            
            btn.Position = UDim2.new(0, 0, 0, count * 34)
            
            btn.MouseButton1Click:Connect(function()
                targetPlayer = p
                dropdown.Text = "▼ " .. p.Name
                listFrame.Visible = false
                statusLabel.Text = "⚡ Aiming at: " .. p.Name .. (isActive and " 🟢 ACTIVE" or "")
            end)
            
            count = count + 1
        end
    end
    
    if count == 1 then
        statusLabel.Text = "⚡ No players found"
    end
    
    listFrame.CanvasSize = UDim2.new(0, 0, 0, count * 36 + 10)
end

-- Dropdown toggle
dropdown.MouseButton1Click:Connect(function()
    listFrame.Visible = not listFrame.Visible
    if listFrame.Visible then
        updateDropdown()
    end
end)

-- Find target from name input
local function getTargetFromName(name)
    if name == "" or name == nil then return nil end
    for _, p in pairs(targetService:GetPlayers()) do
        if p.Name:lower():find(name:lower()) then
            return p
        end
    end
    return nil
end

nameBox.FocusLost:Connect(function()
    local name = nameBox.Text
    if name ~= "" then
        local found = getTargetFromName(name)
        if found then
            targetPlayer = found
            dropdown.Text = "▼ " .. found.Name
            statusLabel.Text = "⚡ Aiming at: " .. found.Name .. (isActive and " 🟢 ACTIVE" or "")
        else
            statusLabel.Text = "⚡ Player not found"
        end
    end
end)

-- Function to get closest arm (target's arm)
local function getClosestArm(character)
    if not character then return nil end
    
    local leftArm = character:FindFirstChild("Left Arm") or character:FindFirstChild("LeftArm")
    local rightArm = character:FindFirstChild("Right Arm") or character:FindFirstChild("RightArm")
    
    if not leftArm and not rightArm then return nil end
    
    if leftArm and not rightArm then return leftArm end
    if rightArm and not leftArm then return rightArm end
    
    local torso = character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso")
    if not torso then return leftArm end
    
    local leftDist = (leftArm.Position - torso.Position).Magnitude
    local rightDist = (rightArm.Position - torso.Position).Magnitude
    
    if leftDist <= rightDist then
        return leftArm
    else
        return rightArm
    end
end

-- Function to get player's arm
local function getPlayerArm()
    local char = getCharacter()
    if not char then return nil end
    
    local arm = char:FindFirstChild("Right Arm") or char:FindFirstChild("RightArm")
    if arm then return arm end
    
    arm = char:FindFirstChild("Left Arm") or char:FindFirstChild("LeftArm")
    return arm
end

