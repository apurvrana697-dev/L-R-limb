-- Variables
local minReach = 5
local maxReach = 30
local currentReach = 10
local isDragging = false

-- Update slider visuals
local function updateSlider(value)
    local clamped = math.clamp(value, minReach, maxReach)
    local percent = (clamped - minReach) / (maxReach - minReach)
    sliderFill.Size = UDim2.new(percent, 0, 1, 0)
    sliderButton.Position = UDim2.new(percent, -9, 0, -6)
    valueLabel.Text = "Reach Distance: " .. math.round(clamped)
    currentReach = math.round(clamped)
end

-- Set reach function
local function setReach(distance)
    local dist = math.round(distance)
    
    -- Method 1: Modify character parts
    local character = player.Character
    if character then
        for _, part in pairs(character:GetDescendants()) do
            if part:IsA("Part") or part:IsA("MeshPart") then
                pcall(function()
                    local size = part.Size
                    local newSize = Vector3.new(size.X, size.Y, size.Z + (dist - 10) * 0.1)
                    part.Size = newSize
                end)
            end
        end
    end
    
    -- Method 2: Global reach variable
    getgenv().Reach = dist
    getgenv().ReachDistance = dist
    
    -- Method 3: Try to find game-specific reach
    for _, obj in pairs(game:GetDescendants()) do
        if obj:IsA("NumberValue") and obj.Name:lower():match("reach") then
            pcall(function()
                obj.Value = dist
            end)
        end
    end
    
    statusLabel.Text = "✓ Reach set to " .. dist
    statusLabel.TextColor3 = Color3.fromRGB(100, 255, 150)
    currentReach = dist
end

-- Slider drag handling
sliderButton.MouseButton1Down:Connect(function()
    isDragging = true
    statusLabel.Text = "⚡ Adjusting..."
    statusLabel.TextColor3 = Color3.fromRGB(255, 200, 50)
end)

mouse.Button1Up:Connect(function()
    if isDragging then
        isDragging = false
        statusLabel.Text = "✓ Ready (click Apply to save)"
        statusLabel.TextColor3 = Color3.fromRGB(100, 255, 150)
    end
end)

mouse.Move:Connect(function()
    if isDragging then
        local framePos = mainFrame.AbsolutePosition
        local frameSize = mainFrame.AbsoluteSize
        local mouseX = mouse.X
        
        -- Calculate position relative to slider track
        local trackX = framePos.X + 10
        local trackWidth = frameSize.X - 20
        
        if mouseX >= trackX and mouseX <= trackX + trackWidth then
            local percent = (mouseX - trackX) / trackWidth
            local value = minReach + (maxReach - minReach) * percent
            updateSlider(value)
        end
    end
end)

-- Also allow clicking on track to set value
sliderTrack.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        local framePos = mainFrame.AbsolutePosition
        local frameSize = mainFrame.AbsoluteSize
        local mouseX = mouse.X
        
        local trackX = framePos.X + 10
        local trackWidth = frameSize.X - 20
        
        if mouseX >= trackX and mouseX <= trackX + trackWidth then
            local percent = (mouseX - trackX) / trackWidth
            local value = minReach + (maxReach - minReach) * percent
            updateSlider(value)
            statusLabel.Text = "⚡ " .. math.round(value) .. " selected"
            statusLabel.TextColor3 = Color3.fromRGB(255, 200, 50)
        end
    end
end)

-- Apply button
updateButton.MouseButton1Click:Connect(function()
