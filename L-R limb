end

-- Keybind handling
userInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    
    if input.KeyCode == Enum.KeyCode.V then
        mainFrame.Visible = not mainFrame.Visible
    end
    
    if waitingForKey then
        if input.KeyCode ~= Enum.KeyCode.Unknown then
            currentKeybind = input.KeyCode
            keybindBtn.Text = "TOGGLE KEY: " .. string.sub(tostring(currentKeybind), 12)
            waitingForKey = false
            keybindBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
        end
        return
    end
    
    if input.KeyCode == currentKeybind then
        toggleHitbox()
    end
end)

-- Slider
local dragging = false
local function updateSlider(mousePos)
    local relativeX = mousePos.X - sliderBg.AbsolutePosition.X
    local width = sliderBg.AbsoluteSize.X
    local percent = math.clamp(relativeX / width, 0, 1)
    sliderFill.Size = UDim2.new(percent, 0, 1, 0)
    sliderValue = minSize + (maxSize - minSize) * percent
    sizeLabel.Text = "HITBOX SIZE: " .. math.round(sliderValue * 100) .. "%"
    
    if isActive then
        applySettings()
    end
end

sliderBg.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        updateSlider(input.Position)
    end
end)

userInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        updateSlider(input.Position)
    end
end)

userInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

