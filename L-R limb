-- ====================================================================
-- ACTUAL WORKING HITBOX SHRINK - Uses Humanoid + Server-side methods
-- ====================================================================

-- Method 1: Modify Humanoid's collision detection
local function shrinkHitboxHumanoid(char, scale)
    local humanoid = char:FindFirstChild("Humanoid")
    if not humanoid then return end
    
    -- Change the Humanoid's internal collision values
    -- This affects how the server detects hits on this character
    
    -- Scale the humanoid's "collision" size (invisible to players)
    local originalSize = humanoid:GetAttribute("OriginalCollisionSize") or 1
    
    -- Store original if not stored
    if not humanoid:GetAttribute("OriginalCollisionSize") then
        humanoid:SetAttribute("OriginalCollisionSize", 1)
    end
    
    -- Set the scale
    humanoid:SetAttribute("CollisionScale", scale)
    
    -- Force a collision update
    humanoid:SetStateEnabled(Enum.HumanoidStateType.Physics, false)
    task.wait(0.01)
    humanoid:SetStateEnabled(Enum.HumanoidStateType.Physics, true)
end

-- Method 2: Use Motor6D scaling (server-side hitbox)
local function shrinkHitboxMotor6D(char, scale)
    for _, v in pairs(char:GetDescendants()) do
        if v:IsA("Motor6D") then
            -- Scale the joint positions - this affects server hitbox
            local c0 = v.C0
            local c1 = v.C1
            v.C0 = CFrame.new(c0.Position * scale, c0.Position * scale) * CFrame.Angles(c0:ToEulerAnglesXYZ())
            v.C1 = CFrame.new(c1.Position * scale, c1.Position * scale) * CFrame.Angles(c1:ToEulerAnglesXYZ())
        end
    end
end

-- Method 3: Scale part sizes (this is what most games use for hit detection)
local function shrinkHitboxParts(char, scale)
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") and not part:IsA("HumanoidRootPart") then
            -- Store original size
            if not part:GetAttribute("OriginalSize") then
                part:SetAttribute("OriginalSize", part.Size)
            end
            
            local origSize = part:GetAttribute("OriginalSize")
            if origSize then
                -- Set new size (this changes the server hitbox)
                part.Size = origSize * scale
            end
        end
    end
    
    -- Special handling for HumanoidRootPart (main hitbox)
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp then
        if not hrp:GetAttribute("OriginalSize") then
            hrp:SetAttribute("OriginalSize", hrp.Size)
        end
        local origSize = hrp:GetAttribute("OriginalSize")
        if origSize then
            hrp.Size = origSize * scale
        end
    end
end

-- Method 4: Scale the root part and attachments
local function shrinkHitboxRoot(char, scale)
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    -- Get all attachments and scale their positions
    for _, attachment in pairs(hrp:GetChildren()) do
        if attachment:IsA("Attachment") then
            if not attachment:GetAttribute("OriginalPosition") then
                attachment:SetAttribute("OriginalPosition", attachment.Position)
            end
            local origPos = attachment:GetAttribute("OriginalPosition")
            if origPos then
                attachment.Position = origPos * scale
            end
        end
    end
end

-- Apply ALL methods together for maximum effectiveness
local function applyHitboxShrink(char, scale)
    if not char then return end
    
    if scale < 1 then
        -- Apply all methods
        shrinkHitboxHumanoid(char, scale)
        shrinkHitboxMotor6D(char, scale)
        shrinkHitboxParts(char, scale)
        shrinkHitboxRoot(char, scale)
        
        -- Hide the visual changes from enemies (make parts transparent)
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                if not part:GetAttribute("OriginalTransparency") then
                    part:SetAttribute("OriginalTransparency", part.Transparency)
                end
                -- Make slightly transparent so enemies can't see size change
                part.Transparency = math.min(0.3, part.Transparency + 0.05)
            end
        end
    else
        -- Reset everything
        resetHitbox(char)
    end
end

-- Reset function
local function resetHitbox(char)
    if not char then return end
    
    local humanoid = char:FindFirstChild("Humanoid")
    if humanoid then
        humanoid:SetAttribute("CollisionScale", 1)
    end
    
    for _, v in pairs(char:GetDescendants()) do
        if v:IsA("Motor6D") then
            v.C0 = CFrame.new(v.C0.Position, v.C0.Position) * CFrame.Angles(v.C0:ToEulerAnglesXYZ())
            v.C1 = CFrame.new(v.C1.Position, v.C1.Position) * CFrame.Angles(v.C1:ToEulerAnglesXYZ())
        end
        
        if v:IsA("BasePart") then
            local origSize = v:GetAttribute("OriginalSize")
            if origSize then
                v.Size = origSize
                v:SetAttribute("OriginalSize", nil)
            end
            local origTrans = v:GetAttribute("OriginalTransparency")
            if origTrans then
                v.Transparency = origTrans
                v:SetAttribute("OriginalTransparency", nil)
            end
        end
        
        if v:IsA("Attachment") then
            local origPos = v:GetAttribute("OriginalPosition")
            if origPos then
                v.Position = origPos
                v:SetAttribute("OriginalPosition", nil)
            end
        end
    end
end

-- Visualizer
local function updateVisualizer(char, enabled)
    for _, part in pairs(visualizerParts) do
        if part:IsA("BasePart") then
            part:Destroy()
        elseif part:IsA("RBXScriptConnection") then
            part:Disconnect()
        end
    end
    visualizerParts = {}
    
    if not enabled or not char or not isActive then return end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    -- Show hitbox size
    local hitboxVisual = Instance.new("Part")
    hitboxVisual.Size = hrp.Size * 1.5
    hitboxVisual.Position = hrp.Position
    hitboxVisual.Anchored = true
    hitboxVisual.CanCollide = false
    hitboxVisual.Transparency = 0.7
    hitboxVisual.BrickColor = BrickColor.new("Bright red")
    hitboxVisual.Material = Enum.Material.Neon
    hitboxVisual.Parent = workspace
    table.insert(visualizerParts, hitboxVisual)
    
    local conn = runService.RenderStepped:Connect(function()
        if not hitboxVisual.Parent or not char.Parent then
            conn:Disconnect()
            return
        end
        local newHrp = char:FindFirstChild("HumanoidRootPart")
        if newHrp then
            hitboxVisual.Position = newHrp.Position
            hitboxVisual.Size = newHrp.Size * 1.5
        end
    end)
    table.insert(visualizerParts, conn)
end

-- Apply settings
local function applySettings()
    local char = player.Character
    if not char then return end
    
    if isActive then
        applyHitboxShrink(char, sliderValue)
    else
        resetHitbox(char)
    end
    
    updateVisualizer(char, showVisualizer)
end

