-- Continuous loop for realtime adjustments
RunService.Heartbeat:Connect(function()
    local char = Player.Character
    if char and char:FindFirstChild("Humanoid") then
        local humanoid = char.Humanoid
        -- Reapply speed to active animations
        for _, track in pairs(humanoid:GetPlayingAnimationTracks()) do
            if track.Name and (track.Name:lower():find("punch") or track.Name:lower():find("m1") or track.Name:lower():find("attack")) then
                local currentSpeed = track.Speed
                local targetSpeed = startupValue
                if math.abs(currentSpeed - targetSpeed) > 0.01 then
                    track:AdjustSpeed(targetSpeed)
                end
            end
        end
    end
end)

