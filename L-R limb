-- ===== AGGRESSIVE INVINCIBILITY =====

local function enableGodMode()
    if not char then return end
    
    -- EVERYTHING gets destroyed or neutralized
    
    -- Connection 1: MAXIMUM HEALTH LOCK
    local c1 = rs.Heartbeat:Connect(function()
        if hum then
            hum.Health = 999999
            hum.MaxHealth = 999999
            hum:SetAttribute("LastDamageTime", -999)
            hum:SetAttribute("DamageCooldown", -999)
            hum:SetAttribute("HitCooldown", -999)
            hum:SetAttribute("LastHit", -999)
            hum.PlatformStand = false
            hum.Sit = false
            hum.AutoRotate = true
        end
        if char then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then
                hrp:SetAttribute("LastDamageTime", -999)
                hrp:SetAttribute("DamageCooldown", -999)
                hrp:SetAttribute("HitCooldown", -999)
            end
        end
    end)
    table.insert(loops, c1)
    
    -- Connection 2: REMOVE ALL HITBOXES CONSTANTLY
    local c2 = rs.Stepped:Connect(function()
        if not char then return end
        for _, obj in ipairs(char:GetDescendants()) do
            -- Remove anything hitbox related
            if obj:IsA("BasePart") then
                obj.CanCollide = false
                obj.Transparency = 0.8
                -- Remove any damage attributes
                obj:SetAttribute("Damage", nil)
                obj:SetAttribute("Hitbox", nil)
                obj:SetAttribute("Owner", nil)
                obj:SetAttribute("IsHitbox", nil)
            end
            -- Kill any damage scripts
            if obj:IsA("Script") or obj:IsA("LocalScript") then
                local name = obj.Name:lower()
                if name:find("hit") or name:find("damage") or name:find("attack") or name:find("combat") then
                    obj:Destroy()
                end
            end
            -- Remove remote events
            if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
                if obj.Name:lower():find("damage") or obj.Name:lower():find("hit") then
                    obj:Destroy()
                end
            end
        end
    end)
    table.insert(loops, c2)
    
    -- Connection 3: BLOCK DAMAGE FIRING
    local c3 = rs.RenderStepped:Connect(function()
        if hum then
            hum.Health = hum.MaxHealth
            hum.BreakJointsOnDeath = false
        end
        if char then
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
        end
    end)
    table.insert(loops, c3)
    
    -- Connection 4: DESTROY NEW HITBOXES AS THEY APPEAR
    local c4 = char.DescendantAdded:Connect(function(obj)
        if obj:IsA("BasePart") then
            obj.CanCollide = false
            obj:SetAttribute("Damage", nil)
            obj:SetAttribute("Hitbox", nil)
        end
        if obj:IsA("Script") or obj:IsA("LocalScript") then
            local name = obj.Name:lower()
            if name:find("hit") or name:find("damage") or name:find("attack") then
                obj:Destroy()
            end
        end
    end)
    table.insert(loops, c4)
end

local function disableGodMode()
    for _, c in ipairs(loops) do
        c:Disconnect()
    end
    loops = {}
    if hum then
        hum.MaxHealth = 100
        hum.Health = 100
        hum.BreakJointsOnDeath = true
    end
    if char then
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = true
                part.Transparency = 0
            end
        end
    end
end

-- ===== TOGGLES =====

local function toggleGod()
    active = not active
    if active then
        toggleBtn.Text = "ACTIVE ✓"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 80)
        dot.BackgroundColor3 = Color3.fromRGB(50, 255, 100)
        status.Text = "ON"
        status.TextColor3 = Color3.fromRGB(100, 255, 150)
        enableGodMode()
    else
        toggleBtn.Text = "ACTIVATE"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 75)
        dot.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
        status.Text = "OFF"
        status.TextColor3 = Color3.fromRGB(255, 100, 100)
        disableGodMode()
    end
end

local function toggleUI()
    uiOpen = not uiOpen
    frame.Visible = uiOpen
    closeBtn.Text = uiOpen and "✕" or "+"
    closeBtn.BackgroundColor3 = uiOpen and Color3.fromRGB(60, 40, 40) or Color3.fromRGB(40, 60, 40)
end

-- ===== INPUT =====
uis.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.F5 then
        toggleUI()
    end
end)

-- ===== BUTTONS =====
toggleBtn.MouseButton1Click:Connect(toggleGod)
closeBtn.MouseButton1Click:Connect(toggleUI)

-- ===== RESPAWN =====
player.CharacterAdded:Connect(function(newChar)
    char = newChar
    hum = char:WaitForChild("Humanoid")
    for _, c in ipairs(loops) do c:Disconnect() end
    loops = {}
    if active then
        enableGodMode()
    end
end)

