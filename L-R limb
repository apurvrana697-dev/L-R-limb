-- Core exploit functions
local function cleanupMods()
    for _, conn in pairs(connections) do
        pcall(function() conn:Disconnect() end)
    end
    connections = {}
    for _, conn in pairs(animConnections) do
        pcall(function() conn:Disconnect() end)
    end
    animConnections = {}
end

local function applyM1Mods()
    cleanupMods()
    
    local char = Player.Character
    if not char then return end
    
    local humanoid = char:FindFirstChild("Humanoid")
    if not humanoid then return end
    
    -- Speed up existing punch animations
    for _, track in pairs(humanoid:GetPlayingAnimationTracks()) do
        if track.Name and (track.Name:lower():find("punch") or track.Name:lower():find("m1") or track.Name:lower():find("attack") or track.Name:lower():find("hit")) then
            track:AdjustSpeed(startupValue)
        end
    end
    
    -- Hook new animations
    local animConn = humanoid.AnimationPlayed:Connect(function(track)
        if track.Name and (track.Name:lower():find("punch") or track.Name:lower():find("m1") or track.Name:lower():find("attack") or track.Name:lower():find("hit")) then
            track:AdjustSpeed(startupValue)
            
            -- Endlag reduction via animation speed boost on the way back
            local stopConn = track.Stopped:Connect(function()
                if char and char:FindFirstChild("HumanoidRootPart") then
                    local root = char.HumanoidRootPart
                    -- Boost velocity to cancel endlag
                    root.Velocity = root.Velocity + Vector3.new(0, 0, 0) * (1 + endlagValue * 0.8)
                end
            end)
            table.insert(animConnections, stopConn)
        end
    end)
    table.insert(connections, animConn)
    
    -- iFrame manipulation - find and modify the combat system
    pcall(function()
        for _, obj in pairs(game:GetDescendants()) do
            if obj:IsA("ModuleScript") and obj.Name and obj.Name:lower():find("combat") then
                local success, module = pcall(function() return require(obj) end)
                if success and type(module) == "table" then
                    -- Attempt to modify hitbox/damage timing for iFrames
                    if module.Damage and type(module.Damage) == "function" then
                        -- Hook the damage function to add iFrame delay
                        local oldDamage = module.Damage
                        module.Damage = function(...)
                            if isActive and iFrameValue > 0 then
                                wait(iFrameValue * 0.05)
                            end
                            return oldDamage(...)
                        end
                    end
                end
            end
        end
    end)
    
    -- Humanoid state changes for iFrame extension
    local stateConn = humanoid.StateChanged:Connect(function(oldState, newState)
        if isActive and (newState == Enum.HumanoidStateType.GettingUp or newState == Enum.HumanoidStateType.Jumping or newState == Enum.HumanoidStateType.Landed) then
            if iFrameValue > 0 then
                -- Many games use this to apply invincibility
                if humanoid:FindFirstChild("BreakJointsOnDeath") then
                    -- Extend invincibility frames
                end
            end
        end
    end)
    table.insert(connections, stateConn)
end

