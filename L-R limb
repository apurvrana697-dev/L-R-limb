-- JJS Roblox Reach Hack
-- Loadstring compatible script
local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/your-library/source/main.lua"))() -- Replace with actual library

local Window = Library:CreateWindow("Reach Hack v1.0")
local Tab = Window:CreateTab("Main")

local ReachSection = Tab:CreateSection("Reach Settings")

local ReachSlider = ReachSection:CreateSlider({
    Name = "Reach Distance",
    Min = 0,
    Max = 50,
    Default = 10,
    Callback = function(value)
        _G.reachValue = value
    end
})

local UpdateButton = ReachSection:CreateButton({
    Name = "Update Reach",
    Callback = function()
        local reach = _G.reachValue or 10
        -- Apply reach modification to local player
        game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = 16 -- keep normal
        -- Custom reach function
        local oldHit
        oldHit = hookfunction(game.Players.LocalPlayer.Character:FindFirstChild("Humanoid").EquipTool, function(...)
            local args = {...}
            local tool = args[1]
            if tool and tool:IsA("Tool") then
                tool.Handle.Size = Vector3.new(reach, reach, reach)
            end
            return oldHit(...)
        end)
        print("Reach updated to " .. tostring(reach))
    end
})

local CloseButton = Tab:CreateButton({
    Name = "Close UI",
    Callback = function()
        Window:Destroy()
    end
})

-- Toggle close with hotkey (Ctrl + C)
game:GetService("UserInputService").InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and input.KeyCode == Enum.KeyCode.C and input:IsModifierKeyDown(Enum.KeyCode.LeftControl) then
        if Window.Enabled then
            Window:Destroy()
        else
            -- Reload if needed
        end
    end
end)

-- Main loop to keep reach persistent
spawn(function()
    while wait(0.5) do
        pcall(function()
            local reach = _G.reachValue or 10
            local char = game.Players.LocalPlayer.Character
            if char then
                for _, v in pairs(char:GetChildren()) do
                    if v:IsA("Tool") and v:FindFirstChild("Handle") then
                        v.Handle.Size = Vector3.new(reach, reach, reach)
                    end
                end
            end
        end)
    end
end)
