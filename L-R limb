-- ===== COLLISION TOGGLE =====

local function toggleCollision()
    collisionOff = not collisionOff
    
    if char then
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = not collisionOff
                if collisionOff then
                    part.Transparency = 0.5
                    part.Material = Enum.Material.Neon
                else
                    part.Transparency = 0
                    part.Material = Enum.Material.Plastic
                end
            end
        end
    end
    
    if collisionOff then
        colBtn.Text = "CLIP OFF"
        colBtn.BackgroundColor3 = Color3.fromRGB(60, 120, 60)
        colStatus.Text = "COLLISION: OFF"
        colStatus.TextColor3 = Color3.fromRGB(255, 200, 100)
    else
        colBtn.Text = "NO CLIP"
        colBtn.BackgroundColor3 = Color3.fromRGB(30, 60, 40)
        colStatus.Text = "COLLISION: ON"
        colStatus.TextColor3 = Color3.fromRGB(100, 255, 150)
    end
end

-- ===== GOD MODE =====

local function enableGod()
    godMode = not godMode
    
    if godMode then
        godBtn.Text = "GOD ON"
        godBtn.BackgroundColor3 = Color3.fromRGB(60, 120, 60)
        godStatus.Text = "GOD MODE: ON"
        godStatus.TextColor3 = Color3.fromRGB(100, 255, 150)
        
        -- God mode loops
        local c1 = rs.Heartbeat:Connect(function()
            if hum then
                hum.Health = hum.MaxHealth
                hum:SetAttribute("LastDamageTime", -999)
                hum:SetAttribute("DamageCooldown", -999)
            end
        end)
        table.insert(loops, c1)
        
        local c2 = rs.Stepped:Connect(function()
            if char then
                for _, obj in ipairs(char:GetDescendants()) do
                    if obj:IsA("Script") or obj:IsA("LocalScript") then
                        local name = obj.Name:lower()
                        if name:find("hit") or name:find("damage") or name:find("attack") then
                            obj:Destroy()
                        end
                    end
                    if obj:IsA("BasePart") then
                        obj.CanCollide = false
                    end
                end
            end
        end)
        table.insert(loops, c2)
        
        local c3 = rs.RenderStepped:Connect(function()
            if hum then
                hum.Health = hum.MaxHealth
            end
        end)
        table.insert(loops, c3)
        
    else
        godBtn.Text = "GOD"
        godBtn.BackgroundColor3 = Color3.fromRGB(60, 30, 30)
        godStatus.Text = "GOD MODE: OFF"
        godStatus.TextColor3 = Color3.fromRGB(255, 100, 100)
        
        for _, c in ipairs(loops) do
            c:Disconnect()
        end
        loops = {}
        
        if hum then
            hum.MaxHealth = 100
            hum.Health = 100
        end
    end
end

-- ===== UI TOGGLE =====

local function toggleUI()
    uiOpen = not uiOpen
    frame.Visible = uiOpen
    close.Text = uiOpen and "✕" or "+"
    close.BackgroundColor3 = uiOpen and Color3.fromRGB(50, 35, 35) or Color3.fromRGB(35, 50, 35)
end

-- ===== KEYBINDS =====
uis.InputBegan:Connect(function(input, gp)
    if gp then return end
    
    if input.KeyCode == Enum.KeyCode.F5 then
        toggleUI()
    elseif input.KeyCode == Enum.KeyCode.F6 then
        toggleCollision()
    elseif input.KeyCode == Enum.KeyCode.F7 then
        enableGod()
    end
end)

-- ===== BUTTONS =====
colBtn.MouseButton1Click:Connect(toggleCollision)
godBtn.MouseButton1Click:Connect(enableGod)
close.MouseButton1Click:Connect(toggleUI)

-- ===== RESPAWN HANDLER =====
player.CharacterAdded:Connect(function(newChar)
    char = newChar
    hum = char:WaitForChild("Humanoid")
    
    for _, c in ipairs(loops) do
        c:Disconnect()
    end
    loops = {}
    
    if collisionOff then
        task.wait(0.1)
        toggleCollision()
    end
    if godMode then
        task.wait(0.1)
        enableGod()
    end
end)

